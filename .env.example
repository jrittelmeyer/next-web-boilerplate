# Copy to .env and fill in. The app validates these at startup (apps/web/src/env.ts).
# Full reference: docs/context/DEPLOYMENT.md

# Database — matches docker/docker-compose.yml defaults for local dev
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/appdb"
# Max connections for the @repo/db pool — optional. Unset → pg's default (10). Set a
# positive integer to size it to your connection budget (see docs/context/DATABASE.md →
# Connection pooling); a set-but-invalid value fails loud at startup.
# DB_POOL_MAX="10"

# Auth (Better Auth)
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-a-random-32-plus-char-secret"
BETTER_AUTH_URL="http://localhost:3000"
# Extra origins Better Auth trusts for CSRF/redirect validation beyond
# BETTER_AUTH_URL — optional, comma-separated (e.g. a separate frontend domain or
# preview deploys). Entries must be URLs or *-wildcard patterns.
# AUTH_TRUSTED_ORIGINS="https://app.example.com,https://preview.example.com"

# Canonical public/marketing origin for SEO metadata (metadataBase, robots, sitemap,
# OG images) — optional. Defaults to BETTER_AUTH_URL. Set this only when the public
# origin differs from the app/auth origin (e.g. marketing on example.com, app on
# app.example.com).
# SITE_URL="https://example.com"

# OAuth providers — optional. Set BOTH id + secret to enable a provider.
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Bot protection — Cloudflare Turnstile CAPTCHA (A12) — optional. Set BOTH to turn on the
# challenge on sign-up / sign-in / password-reset; unset → no plugin, no widget, forms
# unchanged. SECRET is server-only (siteverify); SITE_KEY is the public widget key. Create a
# widget at dash.cloudflare.com → Turnstile. For local testing without an account, Cloudflare
# publishes dummy keys: site 1x00000000000000000000AA + secret
# 1x0000000000000000000000000000000AA always pass (swap the secret to 2x000…AA to always fail).
# See docs/context/AUTH.md → Bot protection / CAPTCHA.
# TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"
# NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"

# Email (Resend) — optional. Without these the app runs but sends are disabled.
# RESEND_API_KEY=""
# EMAIL_FROM="onboarding@resend.dev"   # verified sender: bare address or "Name <address>"
# Webhook signing secret (whsec_…) from the Resend dashboard → Webhooks — optional.
# Set it to authenticate POST /api/resend/webhook (permanent bounces/complaints →
# the email_suppressions do-not-send list) and to turn on the send helper's
# suppression check. See docs/context/SERVICES.md → Resend.
# RESEND_WEBHOOK_SECRET="whsec_..."

# Payments (Stripe) — optional. Without these the app runs but Checkout/webhook
# are disabled. STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET are server-only; the
# publishable key is client-safe (NEXT_PUBLIC_). Get test keys from the Stripe
# Dashboard; STRIPE_WEBHOOK_SECRET is printed by `stripe listen` for local dev.
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# File uploads (Uploadthing) — optional. Without this the app runs but uploads
# are disabled. Get a token from the Uploadthing dashboard (app → API Keys).
# UPLOADTHING_TOKEN="..."

# Search (Meilisearch) — optional. Without these the app runs but search/indexing
# are disabled. Start the engine with docker/docker-compose.yml; the API key must
# match that service's MEILI_MASTER_KEY (default below).
# MEILISEARCH_HOST="http://localhost:7700"
# MEILISEARCH_API_KEY="dev_meili_master_key_change_me"

# Rate limiting — distributed driver (Upstash Redis) — optional. Unset → the
# app-level limiter uses an in-memory per-instance store; set BOTH to switch to a
# distributed sliding-window limiter (required for multi-instance / serverless
# deploys). These exact names are what Redis.fromEnv() reads (see lib/rate-limit.ts).
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Observability — Sentry (errors/traces) — optional. Without NEXT_PUBLIC_SENTRY_DSN
# the SDK is a no-op. The jobs worker reuses the same DSN for dead-lettered-job
# alerts (SERVICES.md → Jobs). ORG/PROJECT/AUTH_TOKEN enable source-map upload at
# build time (CI only); to use it, also flip @sentry/cli to true in
# pnpm-workspace.yaml allowBuilds.
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""   # CI only

# Observability — OpenTelemetry (opt-in) — optional. Set the standard OTLP endpoint
# to export server traces (OTLP/HTTP; the exporter appends /v1/traces) to any OTel
# backend — alongside or without Sentry. Unset → no OTel export, exactly the prior
# behavior. OTEL_EXPORTER_OTLP_HEADERS carries vendor auth (e.g. Honeycomb);
# OTEL_SERVICE_NAME names the service (default "node"). SERVICES.md → OpenTelemetry.
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
# OTEL_SERVICE_NAME="next-web-boilerplate"

# Logging — BetterStack via @logtail/next — optional. Without both the `log` API
# falls back to console. Create a BetterStack "source" (dashboard → Sources) for
# the token + its per-source ingesting host. (LOGTAIL_SOURCE_TOKEN/LOGTAIL_URL also work.)
# BETTER_STACK_SOURCE_TOKEN=""
# BETTER_STACK_INGESTING_URL="https://sXXXXXX.eu-nbg-2.betterstackdata.com"

# Analytics — PostHog (events + feature flags) — optional. Without the key the
# client provider and server client are inert. HOST is the regional ingestion host
# (us or eu); the browser reaches it via the same-origin /ingest proxy (rewrites).
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
