# EditorConfig — https://editorconfig.org
# Values are kept in lockstep with biome.json and .gitattributes so the editor,
# Biome, and Git never disagree about formatting. Biome's own config wins on any
# overlap; these settings cover editors and file types Biome doesn't format.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

# Markdown uses two trailing spaces for hard line breaks — don't strip them.
[*.md]
trim_trailing_whitespace = false

# Keep Windows batch files CRLF if any are ever added.
[*.{bat,cmd}]
end_of_line = crlf
