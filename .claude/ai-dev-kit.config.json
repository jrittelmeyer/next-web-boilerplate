{
  "project": "next-web-boilerplate",
  "packageManager": "pnpm",
  "gate": ["pnpm lint", "pnpm type-check", "pnpm build"],
  "test": {
    "unit": "pnpm test",
    "e2e": "pnpm test:e2e"
  },
  "prodVerify": {
    "build": "pnpm build",
    "start": "pnpm --filter web start -- --port 3100",
    "port": 3100,
    "notes": "Root .env is loaded by the start script (dotenv wrapper); auth origin checks are exact — send an Origin header matching the served URL. Full recipes live in project memory."
  },
  "cache": {
    "size": "pnpm cache:size",
    "prune": "pnpm cache:prune"
  },
  "docs": {
    "dir": "docs",
    "status": "docs/PROJECT_STATUS.md",
    "backlog": "docs/BACKLOG.md",
    "contextDir": "docs/context",
    "archiveDir": "docs/archive"
  },
  "commit": {
    "style": "conventional",
    "trailers": false,
    "useFileFlag": true
  },
  "ci": {
    "provider": "github-actions",
    "workflow": "CI"
  },
  "hygiene": {
    "devPorts": [3000, 3100],
    "e2eUserPattern": "@example.com",
    "keepContainers": ["nwb-postgres", "nwb-meilisearch"]
  },
  "depPolicy": {
    "releaseAgeDays": 7,
    "exactPin": ["lint-staged", "lucide-react"]
  },
  "init": {
    "scaffold": "node scripts/init-app.mjs --slim --name {name}",
    "productBrief": "docs/PRODUCT.md"
  }
}
