{
  "permissions": {
    "allow": [
      "Bash(winget install *)",
      "Bash(pnpm --filter @repo/db db:migrate)",
      "Bash(docker exec *)",
      "Bash(pnpm type-check *)",
      "Bash(pnpm build *)",
      "Bash(pnpm --filter web add -D dotenv-cli@^11.0.0)",
      "Bash(git -c core.safecrlf=false commit -q -m ' *)",
      "Bash(git check-ignore *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/ai-dev-kit/live-verify-reminder.mjs",
            "if": "Bash(git *)",
            "timeout": 10,
            "statusMessage": "ai-dev-kit: live-verify reminder"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/ai-dev-kit/dep-check-nudge.mjs",
            "timeout": 10,
            "statusMessage": "ai-dev-kit: dep-check nudge"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/ai-dev-kit/skill-drift-guard.mjs",
            "timeout": 10,
            "statusMessage": "ai-dev-kit: skill-drift guard"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/ai-dev-kit/context-guard.mjs",
            "timeout": 10,
            "statusMessage": "ai-dev-kit: context guard"
          }
        ]
      }
    ]
  }
}
