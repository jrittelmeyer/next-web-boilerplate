// ⚠️ RECIPE — NOT ACTIVE CODE.
//
// This file ships as `proxy.csp-nonce.ts.example` so Next never loads it (the
// runtime only recognises `proxy.ts`/`proxy.js`) and it stays out of lint/type-
// check. It is the opt-in upgrade from the repo's default STATIC CSP (which uses
// `script-src 'self' 'unsafe-inline'`, set in next.config.ts) to a per-request
// NONCE + 'strict-dynamic' CSP — the gold-standard script-src.
//
// ✅ i18n-AWARE (reworked 2026-07-12). This example IS the current proxy.ts —
// next-intl locale routing (handleI18nRouting), the METADATA_SEGMENTS guard, and
// the locale-stripped auth gate (see docs/context/I18N.md) — with the nonce CSP
// layered AROUND the i18n hand-off. So it's a drop-in again: replace proxy.ts
// with this file and locale routing keeps working (an earlier revision carried
// only the pre-i18n auth gate and would have deleted /es/* routing).
//
// It layers the nonce CSP onto the (locale-aware) optimistic auth-cookie gate. To
// adopt it, follow the steps at the bottom of this file (also in
// docs/context/SECURITY.md → "CSP strategy"). The tradeoff is deliberate and
// documented: every matched route now reads a per-request value, so it renders
// dynamically — you give up the static / Partial-Prerender posture (the static
// `/` landing page) for the stronger CSP.
//
// ⚠️ NOT A ONE-FILE FLIP under this repo's `cacheComponents: true` default. A
// per-request nonce must live in the document shell's inline scripts (next-themes'
// pre-paint script + Next's bootstrap), so the shell must render per-request —
// the opposite of Cache Components' static-shell model. Reading the nonce in the
// [locale] layout actually FAILS the production build with cacheComponents on
// ("/_not-found: Uncached data accessed outside of <Suspense>"). Adopting the
// nonce CSP therefore means going fully dynamic: turn Cache Components OFF and
// unwind the two D4 cache sites (see HOW TO ADOPT step 4 below). This is the
// architectural reversal documented in docs/context/DECISIONS.md → "CSP: static
// default vs nonce upgrade".

import { getSessionCookie } from "better-auth/cookies";
// NextRequest is imported as a VALUE (not `import type`) — the nonce hand-off
// constructs `new NextRequest(...)` to carry the augmented request headers.
import { NextRequest, NextResponse } from "next/server";
import createMiddleware from "next-intl/middleware";
import { routing } from "./i18n/routing";

// ── i18n locale routing (unchanged from proxy.ts) ────────────────────────────
// next-intl negotiates the locale, rewrites the unprefixed default-locale paths
// to the [locale] segment, redirects /en/* → the unprefixed form, and serves
// /es/*. The nonce CSP layers on top: the auth gate + metadata guard run first,
// then the non-gated fall-through hands off to next-intl WITH the nonce headers.
const handleI18nRouting = createMiddleware(routing);

// ── Auth gate (unchanged from proxy.ts) ──────────────────────────────────────
// Optimistic, cookie-only edge redirect for UX; the authoritative session/role
// checks live in the (dashboard) layout + pages. Matched on the locale-STRIPPED
// path so /es/dashboard gates exactly like /dashboard. See proxy.ts and AUTH.md.
const PROTECTED_PREFIXES = ["/dashboard", "/account", "/admin", "/organization"];
const AUTH_PAGES = ["/login", "/signup"];

// Root-level file-based metadata image routes live outside [locale] and serve at
// a dot-less path the broadened matcher would otherwise hand to next-intl (which
// would rewrite them under the default locale and 404 them). Let them pass
// through untouched — they serve images, not script-bearing HTML, so they need
// no nonce/CSP. (The dotted metadata routes — sitemap.xml, robots.txt,
// manifest.webmanifest — are already excluded by the matcher's `.*\..*` clause.)
const METADATA_SEGMENTS = new Set(["opengraph-image", "twitter-image", "icon", "apple-icon"]);

// A leading locale segment on the path ("/es" for /es/dashboard, "" for the
// unprefixed default locale). Used to strip the locale before matching the auth
// prefixes and to keep the login/dashboard redirect targets in the same locale.
const LOCALE_PREFIX = new RegExp(`^/(?:${routing.locales.join("|")})(?=/|$)`);

function localePrefix(pathname: string): string {
  return pathname.match(LOCALE_PREFIX)?.[0] ?? "";
}

function stripLocale(pathname: string): string {
  const stripped = pathname.replace(LOCALE_PREFIX, "");
  return stripped === "" ? "/" : stripped;
}

// ── CSP ───────────────────────────────────────────────────────────────────────
// 'unsafe-eval' and ws: stay dev-only (Turbopack + React Refresh). This MIRRORS
// the directive list in next.config.ts — keep the two in sync when you add or
// remove a SaaS origin — EXCEPT `script-src`, which drops 'unsafe-inline' for
// 'nonce-<nonce>' 'strict-dynamic': only the nonced bootstrap (and the scripts it
// loads) execute. `style-src` KEEPS 'unsafe-inline' — inline `style=` attributes
// (Tailwind/React) can't be nonced and are low-risk.
//
// Note: when a browser honours 'strict-dynamic' it IGNORES 'self' and the host
// allowlist in script-src (js.stripe.com, challenges.cloudflare.com) — those
// scripts are instead trusted transitively because the nonced bootstrap loads
// them. They're left in for older (CSP2) browsers that ignore 'strict-dynamic'.
// challenges.cloudflare.com stays in BOTH script-src and frame-src for the A12
// Turnstile CAPTCHA (its iframe is not script-loaded, so frame-src is not covered
// by 'strict-dynamic'). For wider backwards compatibility you can also append a
// `https:` fallback (CSP1) and 'unsafe-inline' (ignored whenever a nonce is
// present) per Google's strict-CSP guide.
const isDev = process.env.NODE_ENV !== "production";

function buildCsp(nonce: string): string {
  return [
    "default-src 'self'",
    `script-src 'self' 'nonce-${nonce}' 'strict-dynamic'${isDev ? " 'unsafe-eval'" : ""} https://js.stripe.com https://challenges.cloudflare.com`,
    "style-src 'self' 'unsafe-inline'",
    "img-src 'self' blob: data: https:",
    "font-src 'self' data:",
    `connect-src 'self' https://*.sentry.io https://*.posthog.com https://*.uploadthing.com https://*.ingest.uploadthing.com https://api.stripe.com${
      isDev ? " ws:" : ""
    }`,
    "frame-src 'self' https://js.stripe.com https://hooks.stripe.com https://challenges.cloudflare.com",
    "worker-src 'self' blob:",
    "frame-ancestors 'none'",
    "base-uri 'self'",
    "form-action 'self'",
    "object-src 'none'",
    ...(isDev ? [] : ["upgrade-insecure-requests"]),
  ].join("; ");
}

export function proxy(request: NextRequest) {
  const { pathname } = request.nextUrl;

  // Root-level metadata image routes: never localize, gate, or CSP them.
  if (METADATA_SEGMENTS.has(pathname.split("/")[1] ?? "")) {
    return NextResponse.next();
  }

  const prefix = localePrefix(pathname);
  const path = stripLocale(pathname);
  const hasSession = Boolean(getSessionCookie(request));

  // Auth-gate redirects short-circuit before the CSP + i18n work — redirect
  // responses carry no script-bearing body to protect, and a redirect doesn't
  // need locale rewriting. The targets stay locale-correct via `prefix`.
  if (!hasSession && PROTECTED_PREFIXES.some((p) => path.startsWith(p))) {
    const url = new URL(`${prefix}/login`, request.url);
    url.searchParams.set("redirectTo", pathname);
    return NextResponse.redirect(url);
  }

  if (hasSession && AUTH_PAGES.includes(path)) {
    return NextResponse.redirect(new URL(`${prefix}/dashboard`, request.url));
  }

  // Per-request nonce. base64 of a random UUID — opaque and single-use. `crypto`
  // and `Buffer` are both available in Next's Edge runtime (this is the shape
  // from Next's official CSP guide).
  const nonce = Buffer.from(crypto.randomUUID()).toString("base64");
  const csp = buildCsp(nonce);

  // Forward the nonce + CSP on the REQUEST headers, then hand the augmented
  // request to next-intl so it forwards them onto its rewrite. Next reads the
  // nonce out of the request's Content-Security-Policy header and stamps it on
  // every <script> it injects (bootstrap / RSC flight / hydration); read
  // `x-nonce` via headers() in a Server Component (the [locale] layout does, for
  // next-themes' inline script — see step 3) to nonce any manual <script>.
  const requestHeaders = new Headers(request.headers);
  requestHeaders.set("x-nonce", nonce);
  requestHeaders.set("content-security-policy", csp);

  // No gate fired — let next-intl negotiate the locale and rewrite as needed,
  // carrying our augmented request headers through to the render. Then set the
  // CSP on the RESPONSE too, so the browser actually enforces it.
  const response = handleI18nRouting(new NextRequest(request, { headers: requestHeaders }));
  response.headers.set("content-security-policy", csp);
  return response;
}

export const config = {
  // Run on everything except API routes, Next internals, and files with an
  // extension (next-intl's recommended matcher — the same union the i18n routing,
  // the auth gate, AND the nonce CSP all need; the dot-less metadata routes are
  // handled by the METADATA_SEGMENTS guard above). The nonce CSP must cover every
  // HTML route, and this matcher already does; the auth gate is guarded by path
  // checks, so running on more routes is harmless.
  matcher: "/((?!api|_next|_vercel|.*\\..*).*)",
};

// ── HOW TO ADOPT ───────────────────────────────────────────────────────────────
//
// 1. Replace proxy.ts with this file's contents (rename this over proxy.ts, or
//    copy the body across). This file already IS the current proxy.ts (locale
//    routing + the METADATA_SEGMENTS guard + the locale-stripped auth gate) — it
//    just adds the per-request nonce CSP around the i18n hand-off, so nothing is
//    lost by swapping it in.
//
// 2. In next.config.ts, REMOVE the `Content-Security-Policy` entry from
//    `securityHeaders` (leave the other static headers — X-Frame-Options, HSTS,
//    etc. — in place). Otherwise the static CSP and this per-request CSP collide.
//    API / _next routes (excluded by the matcher) then ship no CSP, which is fine
//    — they serve no page scripts. (Keep a minimal static CSP in next.config if
//    you want one there too; just don't duplicate `script-src`.)
//
// 3. In app/[locale]/layout.tsx (the document-shell layout since i18n — it owns
//    <html>/<body> and is already `async`), read the nonce and pass it to any
//    inline script. The only inline script in the default tree is next-themes'
//    pre-paint script, and its provider takes a `nonce` prop (the @repo/ui
//    ThemeProvider wrapper spreads props, so it flows through). PostHog needs
//    nothing — it's bundled and loaded by the nonced bootstrap, so 'strict-
//    dynamic' already trusts it. Reading headers() is what makes the route
//    dynamic — that's the expected tradeoff:
//
//      import { headers } from "next/headers";
//
//      export default async function LocaleLayout({ children, params }: {
//        children: ReactNode;
//        params: Promise<{ locale: string }>;
//      }) {
//        const { locale } = await params;
//        // …existing hasLocale / setRequestLocale…
//        const nonce = (await headers()).get("x-nonce") ?? undefined;
//        return (
//          <html lang={locale} suppressHydrationWarning>
//            <body className="font-sans antialiased">
//              <ThemeProvider nonce={nonce} attribute="class" defaultTheme="system" enableSystem disableTransitionOnChange>
//                {/* …unchanged… */}
//              </ThemeProvider>
//            </body>
//          </html>
//        );
//      }
//
// 4. Turn Cache Components OFF and unwind the D4 cache sites — REQUIRED here. A
//    per-request nonce in the document shell can't coexist with cacheComponents'
//    static shell (the layout's headers() read fails the build on /_not-found):
//      • next.config.ts → `cacheComponents: false`.
//      • components/posts/post-stats.tsx → remove the `"use cache"` directive +
//        `cacheLife("minutes")` / `cacheTag("posts")` (and their next/cache import).
//      • server/actions/post.ts → the cacheComponents-native `updateTag("posts")`
//        calls no longer apply; use `revalidateTag("posts", …)` (Next 16's two-arg
//        signature) or rely on the existing `revalidatePath("/posts")` alone.
//    This reverses D4 (Cache Components) — see DECISIONS.md. If you don't use D4
//    in your fork, this step is just `cacheComponents: false`.
//
// 5. Verify (prod build, fresh port):
//      pnpm --filter web build
//      pnpm --filter web exec next start -p 3100        # (env: load your .env first)
//      curl -sI http://localhost:3100/    | grep -i content-security-policy
//      curl -sI http://localhost:3100/es | grep -i content-security-policy
//        → script-src ... 'nonce-<base64>' 'strict-dynamic'  (no 'unsafe-inline' for scripts)
//      Re-request: the nonce differs each time, and every <script> tag in the HTML
//      (for both the unprefixed default locale AND /es) carries that same nonce.
//      The app's scripts (theme toggle, hydration) run with no CSP violations, and
//      `/` now builds as a dynamic (ƒ) route, not (○).
