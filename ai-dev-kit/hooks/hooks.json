{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/ai-dev-kit/live-verify-reminder.mjs",
            "if": "Bash(git *)",
            "timeout": 10,
            "statusMessage": "ai-dev-kit: live-verify reminder"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/ai-dev-kit/dep-check-nudge.mjs",
            "timeout": 10,
            "statusMessage": "ai-dev-kit: dep-check nudge"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/ai-dev-kit/skill-drift-guard.mjs",
            "timeout": 10,
            "statusMessage": "ai-dev-kit: skill-drift guard"
          }
        ]
      }
    ]
  }
}
